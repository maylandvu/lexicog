{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LexiCog",
  "version": "0.1.0",
  "identifier": "com.mayland.lexicog",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LexiCog",
        "width": 800,
        "height": 600,
        "minWidth": 800,      
        "maxWidth": 1000,      
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/alpha_cube.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": "^https://github\\.com/maylandvu/lexicog/releases(/.*)?$"
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4Q0UzMUVFNUIxMTY1QjIKUldTeVpSRmI3akhPeUtvbFBZWlNBVXFmL2JrNWFJSHFuZXYwYzAvbUYxSDZpSk8yVVVIbWhFSG0K",
      "endpoints": [
        "https://github.com/maylandvu/lexicog/releases/latest/download/latest.json"
      ]
    }
  }
}
